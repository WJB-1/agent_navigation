# 服务器配置
PORT=3002

# MongoDB 配置 - 直接使用 Blind_map 的数据库
MONGODB_URI=mongodb://localhost:27017/blind_map

# 高德地图 Web 服务 API Key
# 获取地址：https://lbs.amap.com/api/webservice/gettingstarted
AMAP_WEB_KEY=YOUR_AMAP_WEB_KEY

# ============================================
# 大模型 API Key 配置 (Phase 4 补充)
# 各平台获取地址：
# - Gemini: https://aistudio.google.com/app/apikey
# - DeepSeek: https://platform.deepseek.com/
# - 阿里云百炼: https://bailian.console.aliyun.com/
# ============================================

# Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# DeepSeek API Key
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# 阿里云百炼 (Qwen) API Key
BAILIAN_API_KEY=YOUR_BAILIAN_API_KEY

# 代理配置 - 根据诊断结果设置正确端口 (Clash 等代理软件)
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897

# 开发环境
NODE_ENV=development